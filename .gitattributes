# Auto detect text files and perform LF normalization
* text=auto

# Enforce LF line endings for Rust source files
*.rs text eol=lf

# Enforce LF for other common source files
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
